# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── PWA Web Push (optional) ─────────────────────────────────────────────────
# Only needed if you want push notifications via the Web Push API.
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
# Paste the "Public Key" here. The "Private Key" goes in your Supabase Edge
# Function secrets (supabase secrets set VAPID_PRIVATE_KEY=...).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Edge Function secrets (set via Supabase CLI, NOT in this file) ──────────
# supabase secrets set VAPID_PRIVATE_KEY=your-vapid-private-key
# supabase secrets set VAPID_PUBLIC_KEY=your-vapid-public-key
# supabase secrets set VAPID_SUBJECT=mailto:admin@yourdomain.com
# supabase secrets set RESEND_API_KEY=re_...
# supabase secrets set EMAIL_FROM_ADDRESS="Soccer Scheduler <noreply@yourdomain.com>"
